# ============================================================
# percolator-fabrknt environment variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Common ---
RPC_URL=https://api.devnet.solana.com
WALLET_PATH=~/.config/solana/id.json

# --- Percolator program ---
PROGRAM_ID=2SSnp35m7FQ7cRLNKGdW5UzjYFF6RBUNq7d3m5mqNByp

# --- BTC Keeper ---
BTC_SLAB=
BTC_ORACLE=
BTC_MINT=
BTC_VAULT=

# --- Privacy Matcher / Solver ---
MATCHER_PROGRAM_ID=Priv1111111111111111111111111111111111111111
MATCHER_CONTEXT=
SOLVER_KEYPAIR=~/.config/solana/id.json
PERCOLATOR_CLI=percolator-cli
POLL_INTERVAL_MS=1000
MAX_SLIPPAGE_BPS=500
INTENT_QUEUE_URL=ws://localhost:8080

# --- Vol Keeper ---
# MATCHER_PROGRAM_ID=VoLm1111111111111111111111111111111111111111
# MATCHER_CONTEXT=
VARIANCE_TRACKER=
VOL_INDEX=
SYNC_INTERVAL_MS=5000

# --- Macro Keeper ---
# MATCHER_PROGRAM_ID=MACm1111111111111111111111111111111111111111
# MATCHER_CONTEXT=
MACRO_ORACLE=
FRED_API_KEY=
# SYNC_INTERVAL_MS=60000

# --- Event Oracle / Keeper ---
# MATCHER_PROGRAM_ID=Evnt1111111111111111111111111111111111111111
# MATCHER_CONTEXT=
EVENT_ORACLE=
PERCOLATOR_MARKET=
UPDATE_INTERVAL_MS=30000
KALSHI_EVENT_SLUG=
KALSHI_API_URL=https://api.elections.kalshi.com/trade-api/v2
POLYMARKET_CONDITION_ID=
POLYMARKET_API_URL=https://clob.polymarket.com

# --- JPY CLI ---
# MATCHER_PROGRAM_ID=JPYm1111111111111111111111111111111111111111
KYC_REGISTRY=
MERIDIAN_PROGRAM_ID=

# --- Next.js Apps (admin, lp-manager, btc, dashboard, etc.) ---
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_PROGRAM_ID=2SSnp35m7FQ7cRLNKGdW5UzjYFF6RBUNq7d3m5mqNByp
NEXT_PUBLIC_BTC_SLAB=
NEXT_PUBLIC_BTC_ORACLE=
NEXT_PUBLIC_BTC_MINT=
NEXT_PUBLIC_BTC_VAULT=
